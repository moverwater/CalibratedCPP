  lambda ~ LogNormal(meanlog=0.1, sdlog=1);
  mu ~ LogNormal(meanlog=0.05, sdlog=1);
  otherNames = ["StripedHyena_Hyaena_hyaena", "ScimitarToothedCat_Homotherium_latidens", "SpottedHyena_Crocuta_crocuta", "Caracal_Caracal_caracal", "Cheetah_Acinonyx_jubatus"];
  rho ~ Uniform(lower=0.0, upper=1.0);
  troot ~ Uniform(lower=29, upper=35);
  tree ~ CalibratedCPP(cladeAge=[t1, t2, t3], cladeTaxa=[taxa1, taxa2, taxa3], lambda=lambda, mu=mu, n=n, otherNames=otherNames, rho=rho, rootAge=troot);
  sigma ~ LogNormal(meanlog=-0.693, sdlog=0.5);
  branchRates ~ UCLN_Mean1(tree=tree, uclnSigma=sigma);
  mRate ~ LogNormal(meanlog=-9, sdlog=5);
  gamma ~ LogNormal(meanlog=0, sdlog=2);
