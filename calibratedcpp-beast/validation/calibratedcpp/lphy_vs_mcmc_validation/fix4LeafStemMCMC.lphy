model {
  taxa_cherry = ["leaf_1", "leaf_2"];
  cCherry = calibration(taxa=taxa_cherry, upper=1.001, lower=1.0);
  calibrations ~ ConditionedMRCAPrior(calibrations=[cCherry]);
  tree ~ CalibratedCPP(
      calibrations = calibrations,
      lambda = 2.0, mu = 1.0, rho = 0.5,
      n = 4, stemAge = 3.0
  );
}
