<beast version='2.0'
       namespace='beastfx.app.beauti:beast.pkgmgmt:beast.base.core:beast.base.inference:beast.base.evolution.branchratemodel:beast.base.evolution.speciation:beast.base.evolution.tree.coalescent:beast.base.util:beast.base.math:beast.evolution.nuc:beast.base.evolution.operator:beast.base.inference.operator:beast.base.evolution.sitemodel:beast.base.evolution.substitutionmodel:beast.base.evolution.likelihood:beast.evolution:beast.base.inference.distribution:beast.base.spec.inference.distribution:beast.base.spec.inference.parameter:beast.base.spec.inference.operator:beast.base.spec.domain:calibratedcpp:calibration:calibrationprior'>

    <mergewith point='treePriorTemplates'>

        <subtemplate id='CalibratedBirthDeathSkyline'
                     class='calibratedcpp.CalibratedBirthDeathSkylineModel'
                     mainid='CalibratedCPP.t:$(n)'
                     suppressInputs='calibratedcpp.CalibratedBirthDeathSkylineModel.calibrations,calibratedcpp.CalibratedBirthDeathSkylineModel.constraintTree,calibratedcpp.CalibratedBirthDeathSkylineModel.birthRate,calibratedcpp.CalibratedBirthDeathSkylineModel.deathRate,calibratedcpp.CalibratedBirthDeathSkylineModel.diversificationRate,calibratedcpp.CalibratedBirthDeathSkylineModel.reproductiveNumber,calibratedcpp.CalibratedBirthDeathSkylineModel.turnover,calibratedcpp.CalibratedBirthDeathSkylineModel.rho,calibratedcpp.CalibratedBirthDeathSkylineModel.conditionOnRoot,calibratedcpp.CalibratedBirthDeathSkylineModel.origin,calibratedcpp.CalibratedBirthDeathSkylineModel.conditionOnCalibrations,calibrationprior.CalibrationPrior.calibration,calibrationprior.CalibrationPrior.constraintTree,calibrationprior.CalibrationPrior.mrcaPrior'
                     hmc='
CalibratedCPPOperator/index/=Operators/BactrianNodeOperator/,
CalibratedCPPSubtreeSlide/index/=Operators/SubtreeSlide/,
CalibratedCPPNarrow/index/=Operators/Exchange/,
CalibratedCPPWide/index/=Operators/Exchange/,
CalibratedCPPWilsonBalding/index/=Operators/WilsonBalding/,
CalibratedCPPBICEPSEpochTop/index/=Operators/EpochFlexer/,
CalibratedCPPBICEPSEpochAll/index/=Operators/EpochFlexer/,
CalibratedCPPBICEPSTreeFlex/index/=Operators/TreeStretcher/,
CalibratedCPPTreeRootScaler/index/=Operators/BactrianTreeScaler/
'>
            <![CDATA[
            <!-- Rate scalars. Default pair (diversificationRate + turnover) is estimated;
                 all others start with estimate=false and are activated by the editor. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="diversificationRate.t:$(n)" domain="Real" value="0.1"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="turnover.t:$(n)" domain="PositiveReal" value="0.5"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="samplingProportion.t:$(n)" domain="Real" value="0.01" estimate="false"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="birthRate.t:$(n)" domain="PositiveReal" value="1.0" estimate="false"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="deathRate.t:$(n)" domain="NonNegativeReal" value="0.5" estimate="false"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="reproductiveNumber.t:$(n)" domain="PositiveReal" value="2.0" estimate="false"/>

            <!-- Origin parameter (always present; ignored when conditionOnRoot=true) -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="originParam.t:$(n)" domain="PositiveReal" value="1.0" estimate="false"/>

            <!-- CPP tree prior. SkylineParameters (diversificationRateSP, turnoverSP, etc.) are
                 NOT declared here — they are created dynamically by CalibratedCPPInputEditor on
                 first init() and persist in the pluginmap. Declaring them in CDATA would cause
                 BEAUti to re-create them (resetting multi-epoch config) on every sync(). -->
            <distribution spec="calibratedcpp.CalibratedBirthDeathSkylineModel" id="CalibratedCPP.t:$(n)"
                          conditionOnRoot="true">
                <tree idref="Tree.t:$(n)"/>
                <rho idref="samplingProportion.t:$(n)"/>
                <origin idref="originParam.t:$(n)"/>
            </distribution>

            <!-- CalibrationPrior: clades and mrcaPriors populated by the BEAUti editor -->
            <distribution spec="calibrationprior.CalibrationPrior" id="CalibrationPrior.t:$(n)">
                <tree idref="Tree.t:$(n)"/>
            </distribution>

            <!-- No priors, operators, or SkylineParameters are pre-declared in CDATA.
                 All are created dynamically by the editor on first activation.
                 This avoids BEAUti re-processing this CDATA on sync() and resetting their state. -->
]]>
            <plate fragment="TreeOperators" var="m" range="CalibratedBirthDeathSkyline"/>

            <!-- Tree prior distributions -->
            <connect srcID='CalibratedCPP.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'>
                Calibrated CPP birth-death skyline prior on tree t:$(n)
            </connect>
            <connect srcID='CalibrationPrior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'>
                CalibrationPrior on clade ages for tree t:$(n)
            </connect>

            <!-- Origin parameter (state/prior/operator/tracelog) -->
            <connect srcID='originParam.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>
            <connect srcID='originParam.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>
            <connect srcID='originParamScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>
            <connect srcID='originParam.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>

            <!-- Priors connected to posterior -->
            <connect srcID='diversificationRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnover.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportion.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumber.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

            <!-- State nodes -->
            <connect srcID='diversificationRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnover.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportion.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumber.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

            <!-- Operators connected to MCMC -->
            <connect srcID='diversificationRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnoverScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportionScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumberScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

            <!-- Logging -->
            <connect srcID='CalibratedCPP.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'/>
            <connect srcID='CalibrationPrior.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'/>
            <connect srcID='diversificationRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnover.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportion.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumber.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

        </subtemplate>

    </mergewith>
</beast>
