<beast version='2.0'
       namespace='beastfx.app.beauti:beast.pkgmgmt:beast.base.core:beast.base.inference:beast.base.evolution.branchratemodel:beast.base.evolution.speciation:beast.base.evolution.tree.coalescent:beast.base.util:beast.base.math:beast.evolution.nuc:beast.base.evolution.operator:beast.base.inference.operator:beast.base.evolution.sitemodel:beast.base.evolution.substitutionmodel:beast.base.evolution.likelihood:beast.evolution:beast.base.inference.distribution:beast.base.spec.inference.distribution:beast.base.spec.inference.parameter:beast.base.spec.inference.operator:beast.base.spec.domain:calibratedcpp:calibration:calibrationprior'>

    <mergewith point='treePriorTemplates'>

        <subtemplate id='CalibratedBirthDeathSkyline'
                     class='calibratedcpp.CalibratedBirthDeathSkylineModel'
                     mainid='CalibratedCPP.t:$(n)'
                     suppressInputs='calibratedcpp.CalibratedBirthDeathSkylineModel.calibrations,calibratedcpp.CalibratedBirthDeathSkylineModel.constraintTree,calibratedcpp.CalibratedBirthDeathSkylineModel.birthRate,calibratedcpp.CalibratedBirthDeathSkylineModel.deathRate,calibratedcpp.CalibratedBirthDeathSkylineModel.diversificationRate,calibratedcpp.CalibratedBirthDeathSkylineModel.reproductiveNumber,calibratedcpp.CalibratedBirthDeathSkylineModel.turnover,calibratedcpp.CalibratedBirthDeathSkylineModel.rho,calibratedcpp.CalibratedBirthDeathSkylineModel.conditionOnRoot,calibratedcpp.CalibratedBirthDeathSkylineModel.origin,calibratedcpp.CalibratedBirthDeathSkylineModel.conditionOnCalibrations,calibrationprior.CalibrationPrior.calibration,calibrationprior.CalibrationPrior.constraintTree,calibrationprior.CalibrationPrior.mrcaPrior'
                     hmc='
CalibratedCPPOperator/index/=Operators/BactrianNodeOperator/,
CalibratedCPPSubtreeSlide/index/=Operators/SubtreeSlide/,
CalibratedCPPNarrow/index/=Operators/Exchange/,
CalibratedCPPWide/index/=Operators/Exchange/,
CalibratedCPPWilsonBalding/index/=Operators/WilsonBalding/,
CalibratedCPPBICEPSEpochTop/index/=Operators/EpochFlexer/,
CalibratedCPPBICEPSEpochAll/index/=Operators/EpochFlexer/,
CalibratedCPPBICEPSTreeFlex/index/=Operators/TreeStretcher/,
CalibratedCPPTreeRootScaler/index/=Operators/BactrianTreeScaler/
'>
            <![CDATA[
            <!-- Rate scalars. Default pair (diversificationRate + turnover) is estimated;
                 all others start with estimate=false and are activated by the editor. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="diversificationRate.t:$(n)" domain="Real" value="0.1"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="turnover.t:$(n)" domain="PositiveReal" value="0.5"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="samplingProportion.t:$(n)" domain="Real" value="0.01" estimate="false"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="birthRate.t:$(n)" domain="PositiveReal" value="1.0" estimate="false"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="deathRate.t:$(n)" domain="NonNegativeReal" value="0.5" estimate="false"/>
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="reproductiveNumber.t:$(n)" domain="PositiveReal" value="2.0" estimate="false"/>

            <!-- Origin parameter: declared so BEAUti tracks it, but NOT connected to the model
                 here. CalibratedCPPInputEditor connects it dynamically when the user selects
                 "Set origin time", and disconnects it when "Condition on root" is selected. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="originParam.t:$(n)" domain="PositiveReal" value="1.0" estimate="false"/>

            <!-- CPP tree prior. SkylineParameters (diversificationRateSP, turnoverSP, etc.) are
                 NOT declared here — they are created dynamically by CalibratedCPPInputEditor on
                 first init() and persist in the pluginmap. Declaring them in CDATA would cause
                 BEAUti to re-create them (resetting multi-epoch config) on every sync(). -->
            <distribution spec="calibratedcpp.CalibratedBirthDeathSkylineModel" id="CalibratedCPP.t:$(n)"
                          conditionOnRoot="true">
                <tree idref="Tree.t:$(n)"/>
                <rho idref="samplingProportion.t:$(n)"/>
            </distribution>

            <!-- CalibrationPrior: clades and mrcaPriors populated by the BEAUti editor -->
            <distribution spec="calibrationprior.CalibrationPrior" id="CalibrationPrior.t:$(n)">
                <tree idref="Tree.t:$(n)"/>
            </distribution>

            <!-- No priors, operators, or SkylineParameters are pre-declared in CDATA.
                 All are created dynamically by the editor on first activation.
                 This avoids BEAUti re-processing this CDATA on sync() and resetting their state. -->
]]>
            <plate fragment="TreeOperators" var="m" range="CalibratedBirthDeathSkyline"/>

            <!-- Tree prior distributions -->
            <connect srcID='CalibratedCPP.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'>
                Calibrated CPP birth-death skyline prior on tree t:$(n)
            </connect>
            <connect srcID='CalibrationPrior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'>
                CalibrationPrior on clade ages for tree t:$(n)
            </connect>

            <!-- Origin parameter (state/prior/operator/tracelog) -->
            <connect srcID='originParam.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>
            <connect srcID='originParam.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>
            <connect srcID='originParamScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>
            <connect srcID='originParam.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and originParam.t:$(n)/estimate=true'/>

            <!-- Priors connected to posterior -->
            <connect srcID='diversificationRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnover.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportion.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumber.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

            <!-- State nodes -->
            <connect srcID='diversificationRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnover.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportion.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumber.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

            <!-- Operators connected to MCMC -->
            <connect srcID='diversificationRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnoverScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportionScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumberScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

            <!-- Logging -->
            <connect srcID='CalibratedCPP.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'/>
            <connect srcID='CalibrationPrior.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'/>
            <connect srcID='diversificationRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and diversificationRate.t:$(n)/estimate=true'/>
            <connect srcID='turnover.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and turnover.t:$(n)/estimate=true'/>
            <connect srcID='samplingProportion.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and samplingProportion.t:$(n)/estimate=true'/>
            <connect srcID='birthRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and birthRate.t:$(n)/estimate=true'/>
            <connect srcID='deathRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and deathRate.t:$(n)/estimate=true'/>
            <connect srcID='reproductiveNumber.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedCPP.t:$(n)) and reproductiveNumber.t:$(n)/estimate=true'/>

        </subtemplate>

        <subtemplate id='CalibratedAgeDependentBirthDeath'
                     class='calibratedcpp.CalibratedAgeDependentBirthDeathModel'
                     mainid='CalibratedAgeDependentBirthDeath.t:$(n)'
                     suppressInputs='calibratedcpp.CalibratedAgeDependentBirthDeathModel.calibrations,calibratedcpp.CalibratedAgeDependentBirthDeathModel.constraintTree,calibratedcpp.CalibratedAgeDependentBirthDeathModel.conditionOnCalibrations,calibratedcpp.CalibratedAgeDependentBirthDeathModel.conditionOnRoot,calibratedcpp.CalibratedAgeDependentBirthDeathModel.origin,calibratedcpp.CalibratedAgeDependentBirthDeathModel.lifetimeDistribution,calibratedcpp.CalibratedAgeDependentBirthDeathModel.rho,calibratedcpp.CalibratedAgeDependentBirthDeathModel.birthRate,calibrationprior.CalibrationPrior.calibration,calibrationprior.CalibrationPrior.constraintTree,calibrationprior.CalibrationPrior.mrcaPrior'
                     hmc='
CalibratedAgeDependentBirthDeathOperator/index/=Operators/BactrianNodeOperator/,
CalibratedAgeDependentBirthDeathSubtreeSlide/index/=Operators/SubtreeSlide/,
CalibratedAgeDependentBirthDeathNarrow/index/=Operators/Exchange/,
CalibratedAgeDependentBirthDeathWide/index/=Operators/Exchange/,
CalibratedAgeDependentBirthDeathWilsonBalding/index/=Operators/WilsonBalding/,
CalibratedAgeDependentBirthDeathBICEPSEpochTop/index/=Operators/EpochFlexer/,
CalibratedAgeDependentBirthDeathBICEPSEpochAll/index/=Operators/EpochFlexer/,
CalibratedAgeDependentBirthDeathBICEPSTreeFlex/index/=Operators/TreeStretcher/,
CalibratedAgeDependentBirthDeathTreeRootScaler/index/=Operators/BactrianTreeScaler/
'>
            <![CDATA[
            <!-- Primary birth rate. Estimated by default. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="adBirthRate.t:$(n)" domain="PositiveReal" value="1.0"/>

            <!-- Extant sampling probability. Fixed at complete sampling (1.0) by default. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="adRho.t:$(n)" domain="UnitInterval" value="1.0" estimate="false"/>

            <!-- Origin parameter: declared so BEAUti tracks it, but NOT connected to the model
                 here. CalibratedAgeDependentBirthDeathInputEditor connects it dynamically when the
                 user selects "Set origin time", and disconnects it when "Condition on root" is
                 selected. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="adOriginParam.t:$(n)" domain="PositiveReal" value="1.0" estimate="false"/>

            <!-- Default lifetime distribution: Exponential(mean). The editor's ChoiceBox creates
                 and reuses Gamma/Erlang/Log-Normal counterparts lazily when the user switches
                 distribution family; their state/prior/operator are NOT pre-declared here. -->
            <stateNode spec="beast.base.spec.inference.parameter.RealScalarParam"
                       id="lifetimeMean.t:$(n)" domain="PositiveReal" value="1.0"/>
            <distribution spec="beast.base.spec.inference.distribution.Exponential"
                          id="lifetimeDistribution.exponential.t:$(n)">
                <mean idref="lifetimeMean.t:$(n)"/>
            </distribution>

            <!-- CPP tree prior -->
            <distribution spec="calibratedcpp.CalibratedAgeDependentBirthDeathModel"
                          id="CalibratedAgeDependentBirthDeath.t:$(n)" conditionOnRoot="true">
                <tree idref="Tree.t:$(n)"/>
                <birthRate idref="adBirthRate.t:$(n)"/>
                <rho idref="adRho.t:$(n)"/>
                <lifetimeDistribution idref="lifetimeDistribution.exponential.t:$(n)"/>
            </distribution>

            <!-- CalibrationPrior: clades and mrcaPriors populated by the BEAUti editor.
                 Uses a distinct ID from the skyline template's CalibrationPrior so the two
                 templates' prior/tracelog connectors don't fight over a shared target (BEAUti
                 evaluates connectors in template order and the last one wins, which would
                 disconnect a shared CalibrationPrior whenever this model is not the active one). -->
            <distribution spec="calibrationprior.CalibrationPrior" id="CalibrationPriorADB.t:$(n)">
                <tree idref="Tree.t:$(n)"/>
            </distribution>

            <!-- No priors or operators are pre-declared for adBirthRate/lifetimeMean here.
                 They are created dynamically by the editor on first activation, mirroring
                 CalibratedCPPInputEditor's handling of the skyline rate parameters. -->
]]>
            <plate fragment="TreeOperators" var="m" range="CalibratedAgeDependentBirthDeath"/>

            <!-- Tree prior distributions -->
            <connect srcID='CalibratedAgeDependentBirthDeath.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'>
                Calibrated age-dependent birth-death prior on tree t:$(n)
            </connect>
            <connect srcID='CalibrationPriorADB.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'>
                CalibrationPrior on clade ages for tree t:$(n)
            </connect>

            <!-- Origin parameter (state/prior/operator/tracelog) -->
            <connect srcID='adOriginParam.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adOriginParam.t:$(n)/estimate=true'/>
            <connect srcID='adOriginParam.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adOriginParam.t:$(n)/estimate=true'/>
            <connect srcID='adOriginParamScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adOriginParam.t:$(n)/estimate=true'/>
            <connect srcID='adOriginParam.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adOriginParam.t:$(n)/estimate=true'/>

            <!-- Birth rate -->
            <connect srcID='adBirthRate.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adBirthRate.t:$(n)/estimate=true'/>
            <connect srcID='adBirthRate.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adBirthRate.t:$(n)/estimate=true'/>
            <connect srcID='adBirthRateScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adBirthRate.t:$(n)/estimate=true'/>
            <connect srcID='adBirthRate.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adBirthRate.t:$(n)/estimate=true'/>

            <!-- Extant sampling probability -->
            <connect srcID='adRho.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adRho.t:$(n)/estimate=true'/>
            <connect srcID='adRho.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adRho.t:$(n)/estimate=true'/>
            <connect srcID='adRhoScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adRho.t:$(n)/estimate=true'/>
            <connect srcID='adRho.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and adRho.t:$(n)/estimate=true'/>

            <!-- Lifetime distribution parameters (only the active family's params ever exist) -->
            <connect srcID='lifetimeMean.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeMean.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeMean.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeMean.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeMeanScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeMean.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeMean.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeMean.t:$(n)/estimate=true'/>

            <connect srcID='lifetimeGammaShape.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaShape.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeGammaShape.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaShape.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeGammaShapeScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaShape.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeGammaShape.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaShape.t:$(n)/estimate=true'/>

            <connect srcID='lifetimeGammaScale.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaScale.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeGammaScale.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaScale.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeGammaScaleScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaScale.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeGammaScale.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeGammaScale.t:$(n)/estimate=true'/>

            <connect srcID='lifetimeErlangScale.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeErlangScale.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeErlangScale.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeErlangScale.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeErlangScaleScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeErlangScale.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeErlangScale.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeErlangScale.t:$(n)/estimate=true'/>

            <connect srcID='lifetimeLogNormalM.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalM.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeLogNormalM.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalM.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeLogNormalMRW.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalM.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeLogNormalM.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalM.t:$(n)/estimate=true'/>

            <connect srcID='lifetimeLogNormalS.t:$(n)' targetID='state' inputName='stateNode'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalS.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeLogNormalS.prior.t:$(n)' targetID='prior' inputName='distribution'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalS.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeLogNormalSScaler.t:$(n)' targetID='mcmc' inputName='operator'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalS.t:$(n)/estimate=true'/>
            <connect srcID='lifetimeLogNormalS.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and lifetimeLogNormalS.t:$(n)/estimate=true'/>

            <!-- Logging -->
            <connect srcID='CalibratedAgeDependentBirthDeath.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'/>
            <connect srcID='CalibrationPriorADB.t:$(n)' targetID='tracelog' inputName='log'
                     if='inposterior(CalibratedAgeDependentBirthDeath.t:$(n)) and inposterior(Tree.t:$(n)) and Tree.t:$(n)/estimate=true'/>

        </subtemplate>

    </mergewith>
</beast>
