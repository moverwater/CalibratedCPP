<package name='calibratedcpp' version='0.0.1'>
    <depends on='BEAST.base' atleast='2.8.0'/>

    <service type="beast.base.core.BEASTInterface">
        <provider classname="calibratedcpp.CalibratedCoalescentPointProcess"/>
        <provider classname="calibratedcpp.CalibratedBirthDeathModel"/>
        <provider classname="calibratedcpp.CalibratedBirthDeathSkylineModel"/>
        <provider classname="calibratedcpp.CalibratedAgeDependentBirthDeathModel"/>
        <provider classname="calibratedcpp.SkylineParameter"/>
        <provider classname="calibratedcpp.distribution.Erlang"/>
        <provider classname="calibrationprior.CalibrationPrior"/>
        <provider classname="calibrationprior.CalibrationCladePrior"/>
        <provider classname="calibration.CalibrationNode"/>
        <provider classname="calibration.CalibrationForest"/>
        <provider classname="calibration.ConstraintTree"/>
    </service>

    <service type="beastfx.app.inputeditor.InputEditor">
        <provider classname="calibratedcpp.beauti.CalibratedCPPInputEditor"/>
        <provider classname="calibratedcpp.beauti.CalibrationPriorInputEditor"/>
        <provider classname="calibratedcpp.beauti.SkylineParameterInputEditor"/>
    </service>
</package>
