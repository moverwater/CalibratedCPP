clade1 = ["leaf_1", "leaf_2"];
clade2 = ["leaf_45", "leaf_46","leaf_47", "leaf_48", "leaf_49", "leaf_50", "leaf_51"];
clade3 = ["leaf_45", "leaf_46","leaf_47", "leaf_48", "leaf_49", "leaf_50", "leaf_51", "leaf_52", "leaf_53", "leaf_54", "leaf_55"];
clade4 = ["leaf_87", "leaf_88", "leaf_89", "leaf_90"];

calibration1 ~ MRCAPrior(age=1.0, taxa=clade1);
calibration2 ~ MRCAPrior(age=1.2, taxa=clade2);
calibration3 ~ MRCAPrior(age=1.5, taxa=clade3);
calibration4 ~ MRCAPrior(age=2.0, taxa=clade4);

calibrationsArray1 = toArray(calibration1 = calibration1, calibration2 = calibration2);
calibrationsArray2 = toArray(calibration1 = calibration3, calibration2 = calibration4);
calibrationsArray = joinArray(calibration1 = calibrationsArray1, calibration2 = calibrationsArray2);

tree ~ CalibratedCPP(lambda=2, mu=1, rho=0.1, n=100, calibrations=calibrationsArray, stemAge=3);